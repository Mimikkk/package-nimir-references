{
  "name": "@nimir/references",
  "version": "0.0.0",
  "description": "Nested resource references resolver for typescript",
  "keywords": [
    "Typescript",
    "typesafe"
  ],
  "homepage": "https://www.github.com/Mimikkk/references",
  "bugs": {
    "url": "https://github.com/Mimikkk/references/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mimikkk/references.git"
  },
  "license": "MIT",
  "author": "Daniel Zdancewicz <zdancewicz.daniel@gmail.com>",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "exports": {
    ".": {
      "development": {
        "default": "./src/exports/lib.ts"
      },
      "types": "./build/exports/lib.d.ts",
      "require": "./build/references.cjs",
      "default": "./build/references.es.js"
    },
    "./react": {
      "development": {
        "default": "./src/exports/react.ts"
      },
      "types": "./build/exports/react.d.ts",
      "require": "./build/react.cjs",
      "default": "./build/react.es.js"
    },
    "./idb-keyval": {
      "development": {
        "default": "./src/exports/idb-keyval.ts"
      },
      "types": "./build/exports/idb-keyval.d.ts",
      "require": "./build/idb-keyval.cjs",
      "default": "./build/idb-keyval.es.js"
    },
    "./redis": {
      "development": {
        "default": "./src/exports/redis.ts"
      },
      "types": "./build/exports/redis.d.ts",
      "require": "./build/redis.cjs",
      "default": "./build/redis.es.js"
    },
    "./in-memory": {
      "development": {
        "default": "./src/exports/in-memory.ts"
      },
      "types": "./build/exports/in-memory.d.ts",
      "require": "./build/in-memory.cjs",
      "default": "./build/in-memory.es.js"
    }
  },
  "main": "./build/references.cjs",
  "module": "./build/references.es.js",
  "source": "./src/exports/lib.ts",
  "files": [
    "build",
    "src",
    "!src/**/*.test.ts",
    "!src/vitest-setup.ts",
    "tsconfig.json",
    "tsconfig.vite.json",
    "vite.config.ts"
  ],
  "scripts": {
    "build": "vite build",
    "dev:samples": "vite --config vite.samples.config.ts",
    "test": "vitest test --exclude src/exports/env.smoke.test.ts",
    "test:env": "pnpm build && vitest run src/exports/env.smoke.test.ts",
    "prepack": "pnpm build"
  },
  "devDependencies": {
    "@testcontainers/redis": "^11.12.0",
    "@types/node": "^24.10.12",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^5.1.4",
    "fake-indexeddb": "^6.2.5",
    "playwright": "^1.49.0",
    "prettier": "^3.8.1",
    "redis": "^5.11.0",
    "rolldown-vite": "^7.3.1",
    "typescript": "^5.9.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "idb-keyval": "^6.2.2",
    "react": "^19.2.4",
    "redis": "^5.11.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "redis": {
      "optional": true
    },
    "idb-keyval": {
      "optional": true
    }
  }
}
